# Supabase — Transaction Pooler (port 6543, mode=transaction)
# Get password from: Supabase Dashboard → Settings → Database → Database password
DATABASE_URL=postgresql+asyncpg://postgres.xaiamosmktaowsxpcrde:[YOUR-DB-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Supabase Auth — get from Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=["http://localhost:4200"]
REDIS_URL=redis://localhost:6379
SENTRY_DSN=
LOG_LEVEL=INFO
ENV=development
